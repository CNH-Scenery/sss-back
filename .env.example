# Copy this file to .env for local execution.
# Never commit a real API key.

POSTGRES_USER=cointwin
POSTGRES_PASSWORD=cointwin
POSTGRES_DB=cointwin

DATABASE_URL=sqlite:///./cointwin.db
BACKEND_DATABASE_URL=postgresql+psycopg://cointwin:cointwin@postgres:5432/cointwin
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
VITE_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
AUTH_SECRET=change-me-to-a-long-random-string

# LLM (Claude / Anthropic) — used by both trading-code generation and the chat agent.
# Real generation requires a valid key; leave CODEGEN_FIXTURE=true to run offline with a stub.
ANTHROPIC_API_KEY=
CODEGEN_MODEL=claude-opus-4-8
CODEGEN_FIXTURE=false
CODEGEN_MAX_ITERATIONS=4
